# OpenAI image API configuration.
# Do not commit real API keys.
# OPENAI_API_KEY is optional if you use the in-app provider configuration or Codex login.
# Environment values are read-only in the app and default to the highest provider priority.
# The top-right "配置" dialog can store one local OpenAI-compatible API config in SQLite;
# saved local keys are masked on readback and never returned in full.
# Do not expose this local app publicly when local provider secrets are configured.
# Leave OPENAI_BASE_URL empty to use the official OpenAI API.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TIMEOUT_MS=1200000

# Codex login uses a mainline Responses model to call the image-generation tool.
# OPENAI_IMAGE_MODEL remains the image model passed to that tool.
CODEX_RESPONSES_MODEL=gpt-5.5

# Server/runtime.
# Codex OAuth token data, local provider keys, generated asset metadata, and app state are
# stored under DATA_DIR in SQLite by default. Treat DATA_DIR as sensitive after saving
# any in-app credentials or generated assets.
PORT=8787
HOST=127.0.0.1
DATA_DIR=./data

# Initial administrator.
# Set all three values together to create or activate the first admin account.
# If the email already exists, startup only ensures role=admin and status=active;
# changing ADMIN_PASSWORD later does not reset an existing password.
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=change-me-local-admin
ADMIN_NAME=Local Admin

# Prompt Pool JSON is bundled in ./prompt-pool-data.
# Images use GitHub raw URLs from that JSON; no local image assets are required.
# Optional: set PROMPT_POOL_DIR to another directory containing prompts-all.json.
PROMPT_POOL_DIR=./prompt-pool-data

# Database storage.
# Set USE_MYSQL=true to store project, asset, generation, and Gallery metadata in MySQL.
# Leave false for the local SQLite default.
USE_MYSQL=false
# Leave blank to use WAL locally; Docker Compose defaults to DELETE + EXCLUSIVE for bind-mounted data.
SQLITE_JOURNAL_MODE=WAL
SQLITE_LOCKING_MODE=NORMAL

# Optional MySQL storage.
# Generated image files still stay under DATA_DIR/assets; MySQL stores relative paths only.
# Use safe placeholder values here. Do not commit real database credentials.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=gpt_image_canvas
MYSQL_PASSWORD=
MYSQL_DATABASE=gpt_image_canvas
MYSQL_CONNECTION_LIMIT=10
MYSQL_CREATE_DATABASE=false
